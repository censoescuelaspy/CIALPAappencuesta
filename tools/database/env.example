PORT=8787
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SYNC_TOKEN=change-me-long-random-token

# Use require/true for Supabase or hosted PostgreSQL endpoints that require TLS.
PGSSLMODE=require

# Optional tuning for Cloud Run or small instances.
PGPOOL_MAX=5
PGCONNECT_TIMEOUT_MS=10000
PGIDLE_TIMEOUT_MS=30000
MAX_BODY_BYTES=12582912
